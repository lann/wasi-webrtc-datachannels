package demo:webrtc-echo@0.1.0;

/// Demo-only interactive prompt used by the browser manual-signaling component.
///
/// A component cannot draw a UI itself, so it drives one through this import:
/// the host renders `present`ed blobs and collects `request`ed blobs from the
/// user (a web form in the browser host). The CLI manual-signaling component
/// does not use this interface — it reads and writes `wasi:cli@0.3` stdio
/// directly — but both components exchange the *same* base64-encoded SDP blobs,
/// so a user can copy/paste between them.
interface prompt {
    /// Present an outgoing signaling blob (base64-encoded SDP) to the user for
    /// them to copy to the peer. `title` labels which blob it is (for example
    /// "offer" or "answer").
    present: async func(title: string, blob: string);

    /// Ask the user to paste an incoming signaling blob (base64-encoded SDP)
    /// received from the peer. `title` labels which blob is expected.
    request: async func(title: string) -> string;

    /// Emit a human-readable status line (progress, the received message, …).
    status: func(message: string);
}

/// The exported entry point for the manual-signaling demo components.
interface manual-demo {
    use lann:webrtc-datachannels/types@0.1.0.{error};

    /// Which half of the exchange this peer drives. The offerer produces the
    /// SDP offer first; the answerer waits for it and replies with an answer.
    enum role {
        offerer,
        answerer,
    }

    /// The outcome of a manual-signaling run.
    record round-trip {
        /// True once the data channel opened and a message was exchanged.
        connected: bool,
        /// The message received from the peer over the data channel.
        peer-message: string,
    }

    /// Drive a full manual-signaling connection as `as-role`: exchange the
    /// offer/answer blobs (via stdio or the `prompt` import), open the data
    /// channel, and send/receive one message to prove the round trip.
    run: async func(as-role: role) -> result<round-trip, error>;
}

/// A minimal, *vanilla* (non-trickle) signaling surface for manual copy/paste
/// connection setup.
///
/// This is a **demo-only** interface (it is not part of the
/// `lann:webrtc-datachannels` package). Unlike that package's `peer-connection`
/// (the full trickle-ICE design target), this interface gathers ICE candidates up
/// front so a whole connection needs just **two** messages: the offerer sends
/// one complete SDP offer (with every candidate already embedded), and the
/// answerer replies with one complete SDP answer (likewise). That is exactly
/// the shape a human can move between two peers by hand — print/copy the offer,
/// paste it into the other side, copy the answer back — which is what the demo
/// `cli-signaling` and `browser-signaling` components do.
///
/// The strings crossing this boundary are raw SDP. Any transport encoding for
/// human copy/paste (for example base64) is the guest's concern; the demo
/// components base64-encode these blobs before showing them to the user.
interface manual-signaling {
    use lann:webrtc-datachannels/types@0.1.0.{error};
    use lann:webrtc-datachannels/connections@0.1.0.{data-channel, data-channel-options};

    /// A peer connection driven with vanilla (non-trickle) ICE.
    ///
    /// Typical offerer flow:
    ///   `create-offer` → show the offer → read the peer's answer →
    ///   `accept-answer` → `connect`.
    /// Typical answerer flow:
    ///   read the peer's offer → `create-answer` → show the answer → `connect`.
    resource peer-connection {
        constructor();

        /// (Offerer) Create the data channel to negotiate, produce an SDP offer,
        /// apply it locally, and block until ICE gathering completes so the
        /// returned SDP already contains every local candidate. The result is
        /// the single blob the offerer hands to the peer.
        create-offer: async func(options: data-channel-options) -> result<string, error>;

        /// (Offerer) Apply the peer's complete SDP answer.
        accept-answer: async func(answer: string) -> result<_, error>;

        /// (Answerer) Apply the peer's complete SDP offer, produce an SDP
        /// answer, apply it locally, and block until ICE gathering completes so
        /// the returned SDP already contains every local candidate. The result
        /// is the single blob the answerer hands back to the peer.
        create-answer: async func(offer: string) -> result<string, error>;

        /// Resolve once the connection is established, yielding the negotiated
        /// data channel (the one the offerer created and the answerer received).
        connect: async func() -> result<data-channel, error>;

        /// Close the peer connection and its data channel.
        close: func();
    }
}

/// The browser manual-signaling demo world: the guest drives `manual-signaling`
/// and does its user I/O through the `prompt` import (a web form).
world browser-signaling-demo {
    import manual-signaling;
    import prompt;
    export manual-demo;
}

/// Host-facing world: the WebRTC imports a native manual-signaling host must
/// provide. The Wasmtime CLI host bindgens this to satisfy the guest's
/// `manual-signaling` import; the guest's `wasi:cli@0.3` imports/exports are
/// provided separately by `wasmtime-wasi`.
world manual-signaling-host {
    import manual-signaling;
}
