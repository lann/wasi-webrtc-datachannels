// The `webrtc-consumer` world.
//
// A minimal consumer of `lann:webrtc-datachannels/connections`: it imports the
// guest-driven `peer-connection` surface and, composed (`wac plug`) against the
// `wasip3-impl` provider component, exercises a full in-guest WebRTC round trip.
//
// The `wasi:cli/run` export and the WASIp3 stdio the consumer prints through
// come from the `wasip3` crate's own bindings, so this world declares only the
// `connections` import that `wac plug` satisfies with the provider's export.
package demo:webrtc-consumer;

world consumer {
    import lann:webrtc-datachannels/connections@0.1.0;
}
