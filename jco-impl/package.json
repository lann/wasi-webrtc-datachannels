{
  "name": "@lann/jco-webrtc-datachannels",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-first (Node) host for lann:webrtc-datachannels, using jco + @roamhq/wrtc.",
  "scripts": {
    "build:component": "cd ../examples/echo-demo && cargo build --release --target wasm32-unknown-unknown && mkdir -p build && wasm-tools component new ../../target/wasm32-unknown-unknown/release/echo_demo.wasm -o build/echo-demo.component.wasm",
    "transpile": "jco transpile ../examples/echo-demo/build/echo-demo.component.wasm --name echo-demo --async-mode jspi --async-exports 'demo:webrtc-echo/demo@0.1.0#run' --async-imports 'lann:webrtc-datachannels/connections@0.1.0#[method]data-channel.send' --async-imports 'lann:webrtc-datachannels/connections@0.1.0#[method]data-channel.receive' --async-imports 'lann:webrtc-datachannels/connections@0.1.0#[method]peer-connection.create-offer' --async-imports 'lann:webrtc-datachannels/connections@0.1.0#[method]peer-connection.create-answer' --async-imports 'lann:webrtc-datachannels/connections@0.1.0#[method]peer-connection.set-local-description' --async-imports 'lann:webrtc-datachannels/connections@0.1.0#[method]peer-connection.set-remote-description' --async-imports 'lann:webrtc-datachannels/connections@0.1.0#[method]peer-connection.add-ice-candidate' --async-imports 'lann:webrtc-datachannels/connections@0.1.0#[method]peer-connection.wait-connected' --map 'lann:webrtc-datachannels/connections@0.1.0=../webrtc.js' -o generated",
    "start": "node src/run.mjs",
    "test": "node src/run.mjs",
    "test:browser": "node test/browser.mjs"
  },
  "devDependencies": {
    "@bytecodealliance/jco": "^1.19.0",
    "playwright-core": "^1.61.1"
  },
  "dependencies": {
    "@roamhq/wrtc": "^0.8.0"
  }
}
