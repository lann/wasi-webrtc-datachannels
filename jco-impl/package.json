{
  "name": "@lann/jco-webrtc-datachannels",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-first (Node) host for lann:webrtc-datachannels, using jco + @roamhq/wrtc.",
  "scripts": {
    "build:component": "cd .. && just build-component",
    "transpile": "jco transpile ../examples/echo-demo/build/echo-demo.component.wasm --name echo-demo --async-mode jspi --async-exports 'demo:webrtc-echo/demo@0.1.0#run' --async-imports 'demo:webrtc-echo/connect@0.1.0#open-echo' --async-imports 'lann:webrtc-datachannels/data-channels@0.1.0#[method]data-channel.send' --async-imports 'lann:webrtc-datachannels/data-channels@0.1.0#[method]data-channel.receive' --map 'demo:webrtc-echo/connect@0.1.0=../webrtc.js' --map 'lann:webrtc-datachannels/data-channels@0.1.0=../webrtc.js' -o generated",
    "start": "node src/run.mjs",
    "test": "node src/run.mjs",
    "test:browser": "node test/browser.mjs"
  },
  "devDependencies": {
    "@bytecodealliance/jco": "^1.19.0",
    "@bytecodealliance/componentize-js": "^0.20.0",
    "playwright-core": "^1.61.1"
  },
  "dependencies": {
    "@roamhq/wrtc": "^0.8.0"
  }
}
