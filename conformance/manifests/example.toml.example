# Example per-target capability manifest.
#
# Copy this to `manifests/<target>.toml` when a phase enables a target. This
# file has a `.toml.example` extension so the runner (which loads `*.toml`) does
# NOT treat it as an enabled target — Phase 0 runs with no targets enabled.
#
# Schema:
#
#   [target]
#   id = "<target-id>"        # matches the adapter's result `target` field and
#                             # one of: wasmtime, jco-node, jco-browser,
#                             # wasip3-guest (or a future target id).
#
#   [[unsupported]]           # zero or more; references TAGS from tests.toml.
#   tag = "<tag>"             # every test carrying this tag becomes
#   reason = "<why>"          # `skip-unsupported` in the matrix (never a
#                             # failure). Reason is mandatory.
#
#   [[expected-fail]]         # zero or more; references TEST IDS from tests.toml.
#   test = "<test-id>"        # this test is known to fail on this target.
#   reason = "<why>"          # mandatory.
#   tracking = "<ref>"        # mandatory tracking reference (e.g. "TODO.md
#                             # item 5") so divergences stay visible. An
#                             # expected-fail that PASSES becomes
#                             # `unexpected-pass` and FAILS the run, forcing the
#                             # manifest to be cleaned up.

[target]
id = "example"

[[unsupported]]
tag = "peer-connection"
reason = "This example target does not implement the peer-connection resource yet."

[[expected-fail]]
test = "error-invalid-signaling"
reason = "Host collapses all failures into error.other."
tracking = "TODO.md item 5"
