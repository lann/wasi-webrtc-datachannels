package lann:webrtc-datachannels@0.1.0;

/// Shared structural types for the WebRTC data-channel interfaces.
///
/// Every non-resource type used by the package lives here. Structural types
/// carry no host-side identity, so a single composition can freely share these
/// definitions across multiple components. The stateful, per-implementation
/// objects — the `data-channel-options`, `data-channel`, and `peer-connection`
/// resources — live in the separate `connections` interface, since a resource
/// is always owned by the one component that implements it.
interface types {
    /// Errors surfaced by peer connections and data channels.
    variant error {
        /// The connection or channel was closed before the operation completed.
        closed,
        /// The signaling or connection attempt timed out.
        timed-out,
        /// A supplied session description or ICE candidate was malformed. The
        /// string carries a human-readable reason.
        invalid-signaling(string),
        /// The channel's inbound messages are being consumed by
        /// `connections.data-channel.receive-via-stream`. Once that method has
        /// been called on a data channel, any further call to it or to `receive`
        /// fails with this error.
        receiving-via-stream,
        /// An implementation-specific failure. The string is human-readable.
        other(string),
    }

    /// A single data-channel message.
    ///
    /// Each message preserves a WebRTC message boundary. A message is either
    /// binary or text; a text message is carried as a `string`, whose bytes are
    /// valid UTF-8.
    variant message {
        /// A binary message, carried verbatim.
        binary(list<u8>),
        /// A text message. The `string` is valid UTF-8.
        %string(string),
    }

    /// The kind of a `stream-message`.
    enum message-kind {
        /// A binary message.
        binary,
        /// A text message. The corresponding `stream-message.data` payload must
        /// be valid UTF-8.
        %string,
    }

    /// A single data-channel message whose payload is carried as a byte
    /// `stream` rather than materialized as a `list<u8>` or `string`.
    ///
    /// The bytes streamed through `data` MUST match `kind` (valid UTF-8 when
    /// `kind` is `string`) and MUST total exactly `length` bytes.
    record stream-message {
        /// Whether the payload is binary or UTF-8 text.
        kind: message-kind,
        /// The total length, in bytes, of the payload carried by `data`.
        length: u32,
        /// The message payload.
        data: stream<u8>,
    }

    /// The failure returned by `connections.data-channel.send-via-stream`.
    ///
    /// `sent` reports how many complete messages were handed to the transport
    /// before `error` occurred, so the caller can tell where the stream stopped.
    record send-via-stream-error {
        /// The failure that stopped the stream.
        error: error,
        /// The number of messages sent before `error` occurred.
        sent: u64,
    }

    /// The kind of an SDP session description.
    enum sdp-type {
        offer,
        answer,
        pranswer,
        rollback,
    }

    /// An SDP session description exchanged during signaling.
    record session-description {
        kind: sdp-type,
        sdp: string,
    }

    /// A trickled ICE candidate.
    record ice-candidate {
        candidate: string,
        sdp-mid: option<string>,
        sdp-mline-index: option<u16>,
    }
}

/// The stateful WebRTC resources: the `data-channel-options` builder, the
/// `data-channel` transport, and the `RTCPeerConnection`-style
/// `peer-connection` that negotiates it.
///
/// These resources carry host-side identity and are owned by the single
/// component that implements them, so — unlike the structural `types` — they
/// cannot be shared across a composition. They are grouped together here so an
/// implementation provides the whole live-object surface in one place.
interface connections {
    use types.{
        error,
        message,
        stream-message,
        send-via-stream-error,
        session-description,
        ice-candidate,
    };

    /// Configuration for a data channel, a subset of `RTCDataChannelInit`
    /// (https://w3c.github.io/webrtc-pc/).
    ///
    /// This is a builder resource, following the shape of `wasi:http`'s
    /// `request-options`: construct a default value, adjust the fields you care
    /// about through the setters, then hand it to `peer-connection`'s
    /// `create-data-channel` (or a demo's `open-echo`/`create-offer`). Each
    /// field has an accessor pair — a getter that reports the current value and
    /// a setter that overrides it.
    resource data-channel-options {
        /// Construct a `data-channel-options` with default field values: an
        /// empty `label`, ordered delivery (`ordered` is `true`), and fully
        /// reliable delivery (`max-retransmits` is `none`).
        constructor();

        /// The channel label. Both peers observe the same label.
        label: func() -> string;
        /// Set the channel label.
        set-label: func(label: string);

        /// Whether messages are delivered in order.
        ordered: func() -> bool;
        /// Set whether messages are delivered in order.
        set-ordered: func(ordered: bool);

        /// The maximum number of retransmissions before a message is dropped,
        /// or `none` for fully reliable delivery.
        max-retransmits: func() -> option<u16>;
        /// Set the maximum number of retransmissions before a message is
        /// dropped. `none` requests fully reliable delivery.
        set-max-retransmits: func(max-retransmits: option<u16>);
    }

    /// A connected, bidirectional WebRTC data channel.
    ///
    /// A data channel is bidirectional and message-oriented. Each
    /// `send`/`receive` carries exactly one data-channel message, preserving
    /// WebRTC message boundaries. Concurrent calls are supported so the host and
    /// guest can pipeline messages and let the async ABI apply backpressure. A
    /// message may be carried as a whole `message` value or, to bound in-memory
    /// buffering, as a `stream-message` whose payload flows through a byte
    /// `stream`.
    resource data-channel {
        /// The negotiated channel label.
        label: func() -> string;

        /// Send a single message on the channel. The returned future resolves
        /// once the message has been handed to the transport, or with an
        /// `error` if the channel closed early.
        ///
        /// Concurrent calls to `send` must be supported; concurrently sent
        /// messages are handed to the transport in an implementation-defined
        /// order.
        send: async func(message: message) -> result<_, error>;

        /// Receive a single message from the channel. The returned future
        /// resolves with the next inbound message, or with an `error` (such as
        /// `closed`) when the channel closes.
        ///
        /// Concurrent calls to `receive` must be supported; concurrently
        /// pending receivers are each handed a message in an
        /// implementation-defined order.
        receive: async func() -> result<message, error>;

        /// Send a stream of messages whose payloads are each streamed as bytes.
        /// Every element of `messages` is one data-channel message, preserving
        /// message boundaries; the bytes streamed through each element's `data`
        /// MUST match its `kind` (valid UTF-8 when `kind` is `string`) and MUST
        /// total exactly its `length` bytes. The returned future resolves once
        /// the input stream is exhausted and every message has been handed to
        /// the transport, or with a `send-via-stream-error` if the channel
        /// closed early. The error's `sent` field reports how many messages were
        /// handed to the transport before the failure.
        ///
        /// Concurrent calls must be supported; concurrently sent messages are
        /// handed to the transport in an implementation-defined order.
        send-via-stream: async func(messages: stream<stream-message>) -> result<_, send-via-stream-error>;

        /// Take over the channel's inbound messages, delivering each as a
        /// `stream-message` whose payload is a byte `stream`. One `stream-message`
        /// is produced per received data-channel message; the returned stream
        /// ends (its reader is dropped) when the channel closes.
        ///
        /// This method may only be called once per channel. Once it has been
        /// called, any further call to it or to `receive` returns
        /// `error.receiving-via-stream`. Any calls to `receive` that are pending
        /// when this method is called are resolved (with
        /// `error.receiving-via-stream`) before this method returns.
        receive-via-stream: func() -> result<stream<stream-message>, error>;
    }

    /// A single WebRTC peer connection driving the full `RTCPeerConnection`-style
    /// signaling surface.
    ///
    /// This is the guest-driven connection surface: it mirrors enough of
    /// `RTCPeerConnection` to drive a real SDP offer/answer exchange and
    /// trickle ICE. It is implemented by the Wasmtime host, the conformance
    /// jco host, and the in-guest `wasip3-impl` provider, and is exercised
    /// across all of them by the conformance suite. See the demo `rendezvous`
    /// interface for the transport that would carry these blobs between remote
    /// peers.
    resource peer-connection {
        constructor();

        /// Create a data channel that will be negotiated in-band with the peer.
        create-data-channel: func(options: data-channel-options) -> result<data-channel, error>;

        /// A stream of data channels opened by the remote peer.
        incoming-data-channels: func() -> stream<data-channel>;

        /// Produce an SDP offer describing the local peer.
        create-offer: async func() -> result<session-description, error>;
        /// Produce an SDP answer in response to a previously set remote offer.
        create-answer: async func() -> result<session-description, error>;
        /// Apply a local description produced by `create-offer`/`create-answer`.
        set-local-description: async func(description: session-description) -> result<_, error>;
        /// Apply the remote peer's description.
        set-remote-description: async func(description: session-description) -> result<_, error>;

        /// A stream of locally gathered ICE candidates to trickle to the peer.
        local-ice-candidates: func() -> stream<ice-candidate>;
        /// Add an ICE candidate received from the remote peer.
        add-ice-candidate: async func(candidate: ice-candidate) -> result<_, error>;

        /// Resolve once the connection reaches the `connected` state.
        wait-connected: async func() -> result<_, error>;

        /// Close the peer connection and any of its data channels.
        close: func();
    }
}
